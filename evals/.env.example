# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required — your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the model used by the v2 per-question provider.
# Defaults to claude-haiku-4-5-20251001 if unset.
# PROMPTFOO_MATCHER_MODEL=claude-haiku-4-5-20251001
